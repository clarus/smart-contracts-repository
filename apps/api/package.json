  "devDependencies": {
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.7",
    "jest": "^29.7.0",
    "prisma": "^6.10.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
